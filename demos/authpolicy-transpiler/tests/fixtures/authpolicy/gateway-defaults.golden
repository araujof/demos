# == CPEX policy document ==
plugin_settings:
  routing_enabled: true
plugins:
- name: jwt-internal
  kind: identity/jwt
  hooks:
  - identity.resolve
  on_error: fail
  config:
    role: user
    header: Authorization
    trusted_issuers:
    - issuer: ''
      algorithms:
      - RS256
      decoding_key:
        kind: jwks_url
        url: https://sso.internal.example.com/jwks
    claim_mapper: standard
global:
  authentication:
  - jwt-internal
  authorization:
    pre_invocation:
    - require(authenticated)
    - cel:
        expr: '!((http.host.endsWith(''.internal.example.com''))) || (((claim.email_verified == true)))'
  pdp:
  - kind: cel

# == Praxis filter block ==
filter: policy
config_path: /etc/praxis/gateway-defaults-cpex-policy.yaml

